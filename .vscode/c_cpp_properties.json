{
    "configurations": [
        {
            "name": "WSL-GCC",
            "includePath": [
                "${workspaceFolder}/**",
                "/usr/include",
                "/usr/include/x86_64-linux-gnu",
                "/usr/lib/gcc/x86_64-linux-gnu/11/include",
                "/usr/lib/gcc/x86_64-linux-gnu/12/include"
            ],
            "defines": [
                "_GNU_SOURCE",
                "__GNUC__"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}
